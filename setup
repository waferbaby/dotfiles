#!/usr/bin/env sh

# Symlink all the things.
mkdir -p ~/.config/

ln -sf ~/.dotfiles/fish/ ~/.config/
ln -sf ~/.dotfiles/nvim/ ~/.config/
ln -sf ~/.dotfiles/alacritty/ ~/.config/

ln -sf ~/.dotfiles/.gitconfig ~/
ln -sf ~/.dotfiles/.gitignore_global ~/
ln -sf ~/.dotfiles/.ripgreprc ~/
ln -sf ~/.dotfiles/.tmux.conf ~/

# Install the base packages.
case $(uname) in
  'Linux')
    sudo apt update

    for item in $(sed -n -E "s/brew \"(.+)\"/\1/p" ~/.dotfiles/Brewfile); do
      sudo apt install $item -y
    done

    sudo apt install build-essential -y

    fish_path=$(which fish)
    ;;
  'Darwin')
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    PATH=$PATH:/opt/homebrew/bin:/usr/local/bin

    brew bundle --file=~/.dotfiles/Brewfile

    brew_prefix=$(brew config | sed -n -E "s/HOMEBREW_PREFIX: (.+)/\1/p")
    fish_path="${brew_prefix}/bin/fish"

    if ! grep -q "${fish_path}" /etc/shells; then
      echo "${fish_path}" | sudo tee -a /etc/shells
    fi
esac

# Install vim-plug.
curl -fLo ~/.dotfiles/nvim/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim

# Install vim plugins.
nvim -E -c PlugInstall -c q -c q

# Switch to fish
chsh -s $fish_path
